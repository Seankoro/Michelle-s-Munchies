# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must never be committed.
# Full launch/deploy guidance: docs/LAUNCH.md

# --- Supabase ---------------------------------------------------------------
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (SGD) — optional, leave blank to take orders over WhatsApp -------
# With these unset, checkout stores the order and hands the customer off to
# WhatsApp to confirm and pay by PayNow. Add the live keys later to switch
# online payment on.
STRIPE_SECRET_KEY=
# From `stripe listen` (local) or the Stripe dashboard webhook (prod).
STRIPE_WEBHOOK_SECRET=
# Optional: not used by the current hosted-checkout flow. Set a pk_live/pk_test
# value only if you later add on-page Stripe Elements.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="Michelle's Munchies <orders@example.com>"
# Where new-order alerts are sent (Michelle's inbox).
OWNER_NOTIFICATION_EMAIL=

# --- Admin access -----------------------------------------------------------
# Comma-separated emails allowed into /admin (enforced in middleware + every
# admin server action). Michelle signs in with a normal account listed here.
ADMIN_EMAILS=

# --- Cron (abandoned-cart + birthday + drop go-live) ------------------------
# Long random string. Vercel Cron sends it as a Bearer token; /api/cron rejects
# requests without it. Set the SAME value in the Vercel project env.
CRON_SECRET=

# --- WhatsApp orders --------------------------------------------------------
# The shop's WhatsApp number as digits in E.164 without the plus, e.g.
# 6591234567. The order confirmation page shows a "Send my order on WhatsApp"
# button that opens a chat to this number with the order pre-filled. Leave
# blank to hide it.
WHATSAPP_NUMBER=

# --- SMS / WhatsApp owner texts (Twilio) — optional, parked -----------------
# Notifications no-op until these are set, so nothing breaks before then.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# For SMS: a Twilio number, e.g. +6531591234 (leave blank to use WhatsApp).
TWILIO_FROM=
# For WhatsApp instead of SMS: e.g. whatsapp:+14155238886 (takes precedence).
TWILIO_WHATSAPP_FROM=
# Michelle's mobile for new-order texts, E.164, e.g. +6591234567
OWNER_NOTIFICATION_PHONE=

# --- Rate limiting (Upstash Redis) — optional -------------------------------
# Leave blank to use the built-in in-memory limiter (per-instance). Set both to
# a free Upstash Redis REST database for a shared limit across serverless
# instances (recommended on Vercel).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App --------------------------------------------------------------------
# Production: set to your final https domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
